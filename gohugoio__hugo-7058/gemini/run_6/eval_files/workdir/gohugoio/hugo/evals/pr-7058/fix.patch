+++ b/hugolib/pagecollections_home_test.go
@@ -0,0 +1,30 @@
+package hugolib
+
+import (
+"testing"
+)
+
+func TestRegularPagesRecursiveHome(t *testing.T) {
+b := newTestSitesBuilder(t)
+
+b.WithConfigFile("yaml", `
+baseURL: "http://example.org/"
+title: "My New Hugo Site"
+`)
+
+b.WithContent(
+"docs/1.md", "\n---title: docs1\n---",
+"_index.md", "\n---title: home\n---",
+"p1.md", "\n---title: p1\n---",
+)
+
+b.WithTemplates("index.html", `
+Home RegularPagesRecursive: {{ range .Site.Home.RegularPagesRecursive }}{{ .RelPermalink}}|{{ end }}|End.
+`)
+
+b.Build(BuildCfg{})
+
+b.AssertFileContent("public/index.html", `
+Home RegularPagesRecursive: /docs/1/|/p1/||End.
+`)
+}
