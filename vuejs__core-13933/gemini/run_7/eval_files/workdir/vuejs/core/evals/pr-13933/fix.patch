index 000000000..6b31d632f
--- /dev/null
+++ b/full-test-global.cjs
@@ -0,0 +1,38 @@
+const { JSDOM, VirtualConsole } = require("jsdom");
+const virtualConsole = new VirtualConsole();
+virtualConsole.on("log", (...args) => console.log(...args));
+virtualConsole.on("error", (...args) => console.error(...args));
+virtualConsole.on("warn", (...args) => console.warn(...args));
+
+const dom = new JSDOM(`
+<!DOCTYPE html>
+<html>
+  <body>
+    <div id="app">
+      <div :type>Fail #1</div>
+      <div v-bind:type>Fail #2</div>
+      <div :type="type">Pass #1</div>
+      <div v-bind:type="type">Pass #2</div>
+    </div>
+  </body>
+</html>
+`, { runScripts: "dangerously", virtualConsole });
+
+global.window = dom.window;
+global.document = dom.window.document;
+
+const VueScript = dom.window.document.createElement('script');
+const fs = require('fs')
+VueScript.textContent = fs.readFileSync('./packages/vue/dist/vue.global.js', 'utf8')
+dom.window.document.head.appendChild(VueScript);
+
+const script = dom.window.document.createElement('script');
+script.textContent = `
+  const app = Vue.createApp({
+    data() { return { type: 'test' } }
+  })
+  app.mount('#app')
+  console.log(document.getElementById('app').innerHTML)
+`;
+dom.window.document.head.appendChild(script);
+
