index 000000000..f1555c188
--- /dev/null
+++ b/test-shorthand.cjs
@@ -0,0 +1,11 @@
+const { compile } = require('./packages/compiler-dom/dist/compiler-dom.cjs.js')
+
+try {
+  let result = compile('<div :param></div>', { prefixIdentifiers: false })
+  console.log('Compile 1 (SFC) success:', result.code)
+  
+  result = compile('<div :param></div>', { prefixIdentifiers: false, isRuntimeDOM: true })
+  console.log('Compile 2 (DOM) success:', result.code)
+} catch (e) {
+  console.error('Compile error:', e)
+}
