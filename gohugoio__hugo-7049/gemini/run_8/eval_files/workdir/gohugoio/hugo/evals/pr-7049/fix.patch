+package metrics
+import (
+"fmt"
+)
+func TestDiffValues() {
+p := NewProvider(true).(*Store)
+p.TrackValue("test1", "hello")
+p.TrackValue("test1", "hello world")
+p.TrackValue("test1", "hello world again")
+p.TrackValue("test1", "hello world again and again")
+d := p.diffs["test1"]
+fmt.Printf("baseline: %v, count: %d, simSum: %d\n", d.baseline, d.count, d.simSum)
+}
