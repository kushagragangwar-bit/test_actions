diff --git a/reproduction.html b/reproduction.html
new file mode 100644
index 000000000..4581c6617
--- /dev/null
+++ b/reproduction.html
@@ -0,0 +1,43 @@
+<!DOCTYPE html>
+<html>
+  <head>
+    <meta charset="utf-8" />
+    <title>Bug Demonstration</title>
+  </head>
+  <body>
+    <div id="app"></div>
+
+    <template id="template-my-comp">
+      <p>{{name}}: param is {{param}}</p>
+    </template>
+
+    <template id="template-app">
+      <!-- NOT WORKING: -->
+      <my-comp name="Fail #1" :param></my-comp>
+      <!-- Working: (comment out the failing case above to see them working) -->
+      <my-comp name="Pass #1" :param="param"></my-comp>
+      <my-comp name="Pass #2" v-bind="{ param }"></my-comp>
+    </template>
+
+    <script src="https://cdn.jsdelivr.net/npm/vue@3.5.22/dist/vue.global.js"></script>
+    <!-- Bug only occuring in v3.5.22, change the version to 3.5.21 to see a working result -->
+    <script>
+      const MyComp = {
+        props: ['name', 'param'],
+        template: '#template-my-comp',
+      };
+
+      const App = {
+        components: { MyComp },
+        setup() {
+          const param = 'orz';
+          return { param };
+        },
+        // Or use: `computed: { param() { return 'orz'; } },`
+        template: '#template-app',
+      };
+
+      Vue.createApp(App).mount('#app');
+    </script>
+  </body>
+</html>
diff --git a/test-shorthand.cjs b/test-shorthand.cjs
