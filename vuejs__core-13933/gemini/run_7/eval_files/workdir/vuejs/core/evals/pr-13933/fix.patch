+const { JSDOM } = require("jsdom");
+const dom = new JSDOM(`
+<!DOCTYPE html>
+<html>
+  <body>
+    <div id="app">
+      <div :type>Fail #1</div>
+      <div v-bind:type>Fail #2</div>
+      <div :type="type">Pass #1</div>
+      <div v-bind:type="type">Pass #2</div>
+    </div>
+  </body>
+</html>
+`);
+
+global.window = dom.window;
+global.document = dom.window.document;
+global.SVGElement = dom.window.SVGElement;
+global.Element = dom.window.Element;
+global.MathMLElement = dom.window.MathMLElement;
+global.__DEV__ = true;
+global.__VUE_OPTIONS_API__ = true;
+global.__VUE_PROD_DEVTOOLS__ = false;
+
+const Vue = require('./packages/vue/dist/vue.cjs.js')
+const app = Vue.createApp({
+  data() {
+    return { type: 'test' }
+  }
+})
+try {
+  app.mount('#app')
+  console.log(document.getElementById('app').innerHTML)
+} catch (e) {
+  console.error("FAIL:", e)
+}
+
