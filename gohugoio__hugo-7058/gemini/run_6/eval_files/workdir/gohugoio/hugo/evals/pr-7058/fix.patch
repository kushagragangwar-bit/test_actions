+package hugolib
+
+import (
+	"testing"
+)
+
+func TestPagesRecursive(t *testing.T) {
+	b := newTestSitesBuilder(t)
+
+	b.WithConfigFile("yaml", `
+baseURL: "http://example.org/"
+title: "My New Hugo Site"
+`)
+
+	b.WithContent(
+		"docs/_index.md", "\n---title: docs\n---",
+		"docs/1.md", "\n---title: docs1\n---",
+		"_index.md", "\n---title: home\n---",
+		"p1.md", "\n---title: p1\n---",
+	)
+
+	b.WithTemplates("index.html", `
+Home Pages: {{ range .Site.Home.Pages }}{{ .RelPermalink}}|{{ end }}|End.
+Site Pages: {{ range .Site.Pages }}{{ .RelPermalink}}|{{ end }}|End.
+`)
+
+	b.Build(BuildCfg{})
+
+	b.AssertFileContent("public/index.html", `
+Home Pages: /docs/|/p1/||End.
+Site Pages: /categories/|/docs/|/docs/1/|/|/p1/|/tags/||End.
+`)
+}
