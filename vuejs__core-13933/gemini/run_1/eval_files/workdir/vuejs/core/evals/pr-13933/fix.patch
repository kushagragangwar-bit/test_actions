+++ b/test-shorthand6.js
@@ -0,0 +1,28 @@
+import { JSDOM } from 'jsdom'
+
+const dom = new JSDOM(`<!DOCTYPE html><html><body><div id="app"></div><template id="template-app"><my-comp name="Fail #1" :param></my-comp></template></body></html>`)
+global.window = dom.window
+global.document = dom.window.document
+global.SVGElement = dom.window.SVGElement
+global.Element = dom.window.Element
+global.Node = dom.window.Node
+
+const vue = await import('./packages/vue/dist/vue.esm-browser.js');
+const { createApp, h } = vue;
+
+const MyComp = {
+  props: ['name', 'param'],
+  template: '<p>{{name}}: param is {{param}}</p>',
+};
+
+const App = {
+  components: { MyComp },
+  setup() {
+    const param = 'orz';
+    return { param };
+  },
+  template: '#template-app'
+}
+
+createApp(App).mount('#app')
+console.log('Result HTML:', document.body.innerHTML)
